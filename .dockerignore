.dockerignore
node_modules
*/node_modules
module-local-dev
*.log
electron-output
webui/build
webui-panels/build
.github
Dockerfile
Dockerfile.*
docker-compose*.yml
.prettier*
dist
*/dist
.cache
# Buddy: local artefacts that shouldn't end up in the image
test-results
playwright-report
Resources
# Note: .git intentionally NOT excluded. tools/lib.mts uses `git rev-parse`
# to embed the build version, and husky's postinstall (when not disabled via
# HUSKY=0) needs git hooks present. Shipping .git adds ~100 MB to the build
# context — acceptable trade-off for build correctness.
